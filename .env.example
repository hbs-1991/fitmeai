# Anthropic — choose ONE:
# Option A: OAuth token from subscription (preferred, $0 cost)
# Run: claude setup-token
ANTHROPIC_AUTH_TOKEN=
# Option B: API key (paid per token)
# ANTHROPIC_API_KEY=sk-ant-...

# Telegram Bot (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Owner Chat ID (restrict bot to single user, get via @userinfobot)
# OWNER_CHAT_ID=

# OpenAI (Whisper voice transcription only)
OPENAI_API_KEY=

# FatSecret API Credentials (get from https://platform.fatsecret.com/api)
FATSECRET_CLIENT_ID=your_client_id_here
FATSECRET_CLIENT_SECRET=your_client_secret_here

# OAuth Configuration
FATSECRET_OAUTH_CALLBACK_URL=http://localhost:8080/callback
FATSECRET_TOKEN_STORAGE=keyring

# Server Configuration
LOG_LEVEL=INFO
LOG_FILE=fatsecret_mcp.log

# API Configuration
FATSECRET_API_BASE_URL=https://platform.fatsecret.com/rest/server.api
FATSECRET_OAUTH_BASE_URL=https://www.fatsecret.com/oauth
